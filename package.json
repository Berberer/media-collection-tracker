{
  "name": "media-collection-tracker",
  "version": "0.1.4",
  "scripts": {
    "ng": "ng",
    "start": "npm run typegen && ( pocketbase serve & ng serve )",
    "start:mock": "npm run typegen && ng serve --configuration=mock",
    "typegen": "pocketbase-typegen --db pb_data/data.db --out src/pocketbase-types.ts",
    "build": "npm run typegen && ng build",
    "lint": "ng lint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{ts,html,scss,css,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.13",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/heroicons": "^33.2.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@ngxs/router-plugin": "^21.0.0",
    "@ngxs/store": "^21.0.0",
    "color-hash": "^2.0.2",
    "contrast-ratio-checker": "^1.1.7",
    "pocketbase": "^0.26.9",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@ngxs/devtools-plugin": "^21.0.0",
    "@rxlint/eslint-plugin": "^1.3.12",
    "@rxlint/eslint-plugin-angular": "^1.2.13",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/color-hash": "^2.0.0",
    "@typescript-eslint/parser": "^8.51.0",
    "angular-eslint": "^21.4.0",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "pocketbase-typegen": "^1.5.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-eslint": "16.4.2",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
