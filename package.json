{
  "name": "media-collection-tracker",
  "version": "0.1.10",
  "scripts": {
    "ng": "ng",
    "start": "npm run typegen && ( pocketbase serve & ng serve )",
    "start:mock": "npm run typegen && ng serve --configuration=mock",
    "typegen": "pocketbase-typegen --db pb_data/data.db --out src/pocketbase-types.ts",
    "build": "npm run typegen && ng build",
    "lint": "ng lint",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --collect-coverage",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{ts,html,scss,css,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "standard-version": {
    "skip": {
      "changelog": false,
      "tag": false
    },
    "tagPrefix": "v",
    "sign": false
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@ng-icons/core": "^33.3.0",
    "@ng-icons/heroicons": "^33.3.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "color-hash": "^2.0.2",
    "contrast-ratio-checker": "^1.1.7",
    "pocketbase": "^0.27.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@eslint/js": "^10.0.1",
    "@ngxs/devtools-plugin": "^22.0.0",
    "@ngxs/router-plugin": "^22.0.0",
    "@ngxs/store": "^22.0.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/color-hash": "^2.0.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.51.0",
    "angular-eslint": "^22.0.0",
    "daisyui": "^5.6.13",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-rxjs-angular-x": "^1.0.1",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^17.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "pocketbase-typegen": "^1.5.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "standard-version": "^9.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
